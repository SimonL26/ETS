{
  "name": "ets-backend",
  "version": "1.0.0",
  "description": "Expense Tracking System — Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node --project config/tsconfig.json src/index.ts",
    "build": "tsc -p config/tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest -c config/jest.config.ts",
    "test:watch": "jest -c config/jest.config.ts --watch",
    "test:coverage": "jest -c config/jest.config.ts --coverage"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.9",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
